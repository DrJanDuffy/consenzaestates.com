{
	"name": "odyssey-theme",
	"version": "3.1.0",
	"private": false,
	"repository": {
		"type": "git",
		"url": "git@github.com:treefarmstudio/odyssey-theme"
	},
	"scripts": {
		"dev": "astro dev --host 0.0.0.0 --port 5000",
		"start": "npx http-server ./dist -p 5000 --cors -a 0.0.0.0",
		"check-headshots": "node scripts/check-headshots.cjs",
		"build": "astro build --config astro.config.mjs",
		"preview": "astro preview --host 0.0.0.0 --port 5000",
		"format": "npx prettier -w ."
	},
	"devDependencies": {
		"@astrojs/lit": "^4.3.0",
		"@astrojs/mdx": "^4.3.13",
		"@astrojs/sitemap": "^3.7.0",
		"@webcomponents/template-shadowroot": "^0.2.1",
		"astro": "^5.18.0",
		"date-fns": "^4.1.0",
		"lit": "^3.3.2",
		"prettier-plugin-astro": "^0.14.1"
	},
	"engines": {
		"node": "24.x"
	}
}
