---
/**
 * RealScout office listings widget. Script is loaded once in Base.astro.
 * Place directly below the hero on every page (primary lead generator).
 */
const { sectionTitle = 'Homes for Sale', class: className = '' } = Astro.props;
---
<section class={`realscout-listings-section ${className}`} aria-label="Property listings">
  <div class="realscout-listings-inner">
    <h2 class="realscout-listings-title">{sectionTitle}</h2>
    <realscout-office-listings
      agent-encoded-id="QWdlbnQtMjI1MDUw"
      sort-order="PRICE_HIGH"
      listing-status="For Sale"
      property-types="SFR,MF,TC"
      price-min="500000"
    />
  </div>
</section>
<style>
  .realscout-listings-section {
    padding: 2rem 0;
  }
  .realscout-listings-inner {
    width: 100%;
    max-width: var(--container-width, 1200px);
    margin: 0 auto;
    padding: 0 1rem;
  }
  .realscout-listings-title {
    margin-bottom: 1.5rem;
    font-size: 1.5rem;
  }
  .realscout-listings-section :global(realscout-office-listings) {
    --rs-listing-divider-color: rgb(101, 141, 172);
    width: 100%;
  }
</style>
