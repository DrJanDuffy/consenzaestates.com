---
import settings from '../../config/settings.js';
import ThemeProvider from '../theme-switcher/ThemeProvider.astro';

import '../../styles/index.css';

export interface Props {
	title?: string;
	description?: string;
	canonicalURL?: URL | string;
	image?: string;
	/** OG/Twitter image width (default 1200). */
	imageWidth?: number;
	/** OG/Twitter image height (default 630). */
	imageHeight?: number;
}

const title = Astro.props.title || settings.title;
const description = Astro.props.description || settings.description;
const canonicalURL = Astro.props.canonicalURL || new URL(Astro.url.pathname, Astro.site);
const image = new URL(Astro.props.image || './social.png', Astro.site);
const imageWidth = Astro.props.imageWidth ?? settings.seo?.openGraph?.images?.[0]?.width ?? 1200;
const imageHeight = Astro.props.imageHeight ?? settings.seo?.openGraph?.images?.[0]?.height ?? 630;
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<link rel="icon" type="image/png" href="/favicon.png" />
<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />
<link rel="canonical" href={canonicalURL} />
<link rel="sitemap" href={new URL('/sitemap-index.xml', Astro.site)} type="application/xml" />
<!-- Google Search Console verification (set PUBLIC_GOOGLE_SITE_VERIFICATION in .env) -->
{import.meta.env.PUBLIC_GOOGLE_SITE_VERIFICATION && (
	<meta name="google-site-verification" content={import.meta.env.PUBLIC_GOOGLE_SITE_VERIFICATION} />
)}
<!-- Generator -->
<meta name="generator" content={Astro.generator} />
<!-- Open Graph / Facebook -->
<meta property="og:type" content="website" />
<meta property="og:locale" content={settings.seo?.openGraph?.locale ?? 'en_US'} />
<meta property="og:site_name" content={settings.seo?.openGraph?.site_name ?? settings.name} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={image} />
<meta property="og:image:width" content={String(imageWidth)} />
<meta property="og:image:height" content={String(imageHeight)} />

<!-- Twitter -->
<meta property="twitter:card" content={settings.seo?.twitter?.cardType ?? 'summary_large_image'} />
<meta property="twitter:site" content={settings.seo?.twitter?.site ?? ''} />
<meta property="twitter:creator" content={settings.seo?.twitter?.handle ?? ''} />
<meta property="twitter:url" content={canonicalURL} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={image} />
<meta property="twitter:image:width" content={String(imageWidth)} />
<meta property="twitter:image:height" content={String(imageHeight)} />

<!-- For Demonstration of the themes -->
{settings.enableThemeSwitcher && <ThemeProvider />}

<!-- JSON-LD: LocalBusiness + RealEstateAgent (NAP, GBP alignment) -->
<script type="application/ld+json" set:html={JSON.stringify({
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'RealEstateAgent',
      '@id': `${settings.url}/#organization`,
      name: settings.name,
      url: settings.url,
      telephone: settings.contact?.phone,
      email: settings.contact?.email,
      address: {
        '@type': 'PostalAddress',
        streetAddress: settings.contact?.address?.split(',')[0]?.trim() ?? '',
        addressLocality: 'Las Vegas',
        addressRegion: 'NV',
        postalCode: settings.contact?.address?.match(/\d{5}/)?.[0] ?? '89113',
        addressCountry: 'US'
      },
      image: new URL(settings.site?.logo ?? '/assets/images/logo.png', settings.url).toString(),
      sameAs: settings.social ? Object.values(settings.social).filter(Boolean) : []
    },
    {
      '@type': 'Person',
      '@id': `${settings.url}/#agent`,
      name: 'Dr. Jan Duffy',
      jobTitle: 'REALTOR®',
      worksFor: { '@id': `${settings.url}/#organization` },
      telephone: settings.contact?.phone,
      email: settings.contact?.email,
      description: settings.description
    }
  ]
})} />

<!-- Google Analytics -->
<script>
  var host = window.location.hostname;
  if(host != 'localhost') {
    // Place Google Analytics code here.
  }
</script>
