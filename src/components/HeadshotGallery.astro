---
// Single headshot for homepage: Dr. Jan Duffy with E-E-A-T–friendly alt text.
const headshot = {
  src: '/assets/images/headshots/jan-duffy-1.jpg',
  alt: 'Dr. Jan Duffy, Consenza Estates and Las Vegas luxury real estate specialist, professional headshot',
};
---

<section class="headshot-gallery-section">
  <div class="headshot-single">
    <div class="headshot-main">
      <img src={headshot.src} alt={headshot.alt} width="400" height="400" loading="eager" />
      <div class="headshot-overlay">
        <h3>Dr. Jan Duffy</h3>
        <p>Las Vegas Luxury Real Estate Specialist</p>
      </div>
    </div>
  </div>

  <div class="agent-credentials">
    <div class="credential-item">
      <div class="credential-icon">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="8" r="7"></circle>
          <polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"></polyline>
        </svg>
      </div>
      <div class="credential-content">
        <h3>Certified Luxury Home Marketing Specialist</h3>
        <p>Specialized training for high-end property representation</p>
      </div>
    </div>

    <div class="credential-item">
      <div class="credential-icon">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path>
          <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path>
        </svg>
      </div>
      <div class="credential-content">
        <h3>Certified New Home Specialist</h3>
        <p>Expert in new construction and builder representation</p>
      </div>
    </div>

    <div class="credential-item">
      <div class="credential-icon">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 2L2 7l10 5 10-5-10-5z"></path>
          <path d="M2 17l10 5 10-5"></path>
          <path d="M2 12l10 5 10-5"></path>
        </svg>
      </div>
      <div class="credential-content">
        <h3>Top 1% of Las Vegas Real Estate Professionals</h3>
        <p>Consistently recognized for outstanding performance</p>
      </div>
    </div>
  </div>
</section>

<style>
.headshot-gallery-section {
  padding: 2rem 0;
}

.headshot-single {
  max-width: 500px;
  margin: 0 auto;
}

.headshot-main {
  position: relative;
  border-radius: 12px;
  overflow: hidden;
  box-shadow: var(--luxury-shadow-md, 0 10px 15px rgba(0,0,0,0.1));
}

.headshot-main img {
  width: 100%;
  height: auto;
  aspect-ratio: 1;
  object-fit: cover;
  display: block;
}

.headshot-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 1.5rem;
  background: linear-gradient(to top, rgba(0,0,0,0.8), rgba(0,0,0,0));
  color: white;
}

.headshot-overlay h3 {
  margin-bottom: 0.5rem;
  font-weight: 700;
}

.agent-credentials {
  margin-top: 3rem;
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
  gap: 2rem;
}

.credential-item {
  display: flex;
  align-items: flex-start;
  background: var(--theme-surface-1);
  padding: 1.5rem;
  border-radius: 8px;
  box-shadow: var(--luxury-shadow-sm, 0 4px 6px rgba(0,0,0,0.05));
  transition: transform 0.3s ease, box-shadow 0.3s ease;
}

.credential-item:hover {
  transform: translateY(-5px);
  box-shadow: var(--luxury-shadow-md, 0 10px 15px rgba(0,0,0,0.1));
}

.credential-icon {
  width: 40px;
  height: 40px;
  min-width: 40px;
  margin-right: 1rem;
  color: var(--luxury-gold, #D4AF37);
}

.credential-content h3 {
  margin-bottom: 0.5rem;
  font-size: 1.1rem;
}

.credential-content p {
  font-size: 0.9rem;
  color: var(--theme-on-bg);
  opacity: 0.8;
}
</style>
