
---
import { Container, TextSection } from '@components/odyssey-theme.js';
import Layout from '@layouts/Page.astro';
import HeroSection from '@components/sections/heros/HeroSection.astro';
import CalendlyLink from '@components/CalendlyLink.astro';
import RealScoutListings from '../components/RealScoutListings.astro';

const seo = {
  title: 'Consenza Estates Properties | Dr. Jan Duffy',
  description: 'Browse current listings in Consenza Estates. Find your dream Lennar home in this exclusive Las Vegas community.'
};
---

<Layout {seo}>
  <HeroSection>
    <div slot="text-container">
      <h1>Consenza Estates Properties</h1>
      <p>Discover available homes in this exclusive Lennar community.</p>
    </div>
    <picture slot="image-container">
      <img
        src="/assets/images/home/consenza-property.jpg"
        alt="Luxury home in Consenza Estates"
        id="property-hero-image"
      />
    </picture>
  </HeroSection>

  <RealScoutListings sectionTitle="Current Listings in Consenza Estates" />

  <Container>
    <TextSection>
      <h2>Why Browse Listings With Dr. Jan Duffy</h2>
      <p>As your Consenza Estates and Las Vegas specialist, Dr. Jan Duffy can provide detailed information on any listing and arrange private showings.</p>
      <h3>Consenza Estates & Lennar Specialist</h3>
      <p>Dr. Duffy has in-depth knowledge of Lennar homes and the Consenza Estates community.</p>
      <h3>Full-Service Representation</h3>
      <p>Berkshire Hathaway HomeServices Nevada Properties (S.0197614.LLC) offers full buyer and seller representation across the Las Vegas area.</p>
    </TextSection>
    <div class="property-schedule-cta">
      <TextSection>
        <h2>Find Your Perfect Home</h2>
        <p>Book a free call to discuss features, private showings, and the best Consenza Estates options for you. Free 15‑minute call — no obligation.</p>
        <h3>Schedule a Call</h3>
        <p>
          <CalendlyLink utmCampaign="properties_cta">Book a free call</CalendlyLink>
        </p>
      </TextSection>
    </div>
  </Container>
</Layout>

<style>
  .property-schedule-cta {
    margin-top: 4rem;
    padding: 2rem;
    background-color: var(--theme-surface-2);
    border-radius: var(--theme-shape-radius);
  }
  .property-schedule-cta p:last-of-type {
    margin-top: 1rem;
  }
</style>
