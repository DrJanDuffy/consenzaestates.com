
---
import { Container, TextSection } from '@components/odyssey-theme.js';
import Layout from '@layouts/Page.astro';
import HeroSection from '@components/sections/heros/HeroSection.astro';
import CalendlyLink from '@components/CalendlyLink.astro';

const seo = {
  title: 'Consenza Estates Properties | Dr. Jan Duffy',
  description: 'Browse current listings in Consenza Estates. Find your dream Lennar home in this exclusive Las Vegas community.'
};
---

<Layout {seo}>
  <HeroSection>
    <div slot="text-container">
      <h1>Consenza Estates Properties</h1>
      <p>Discover available homes in this exclusive Lennar community.</p>
    </div>
    <picture slot="image-container">
      <img
        src="/public/assets/images/home/consenza-property.jpg"
        alt="Luxury home in Consenza Estates"
        id="property-hero-image"
      />
    </picture>
  </HeroSection>

  <Container>
    <TextSection>
      <h2>Current Listings in Consenza Estates</h2>
      <p>Browse the latest available properties in Consenza Estates. As your dedicated specialist in this community, I can provide detailed information about any listing that catches your eye. Contact me for private showings or to discuss new construction opportunities.</p>
    </TextSection>

    <div class="property-listings">
      <script src="https://em.realscout.com/widgets/realscout-web-components.umd.js" type="module"></script>
      <style>
        realscout-office-listings {
          --rs-listing-divider-color: rgb(101, 141, 172);
          width: 100%;
          margin: 2rem 0;
        }
      </style>
      <realscout-office-listings 
        agent-encoded-id="QWdlbnQtMjI1MDUw" 
        sort-order="PRICE_HIGH" 
        listing-status="For Sale" 
        property-types="SFR,MF,TC" 
        price-min="500000">
      </realscout-office-listings>
    </div>

    <div class="property-schedule-cta">
      <TextSection>
        <h2>Find Your Perfect Home</h2>
        <p>Looking for specific features or a private showing? Schedule a call and we'll narrow down the best Consenza Estates options for you.</p>
        <p>
          <CalendlyLink>Schedule a call</CalendlyLink>
        </p>
      </TextSection>
    </div>
  </Container>
</Layout>

<style>
  .property-schedule-cta {
    margin-top: 4rem;
    padding: 2rem;
    background-color: var(--theme-surface-2);
    border-radius: var(--theme-shape-radius);
  }
  .property-schedule-cta p:last-of-type {
    margin-top: 1rem;
  }
</style>
