---
import { TextSection, Container } from '@components/odyssey-theme.js';
import Layout from '@layouts/Page.astro';
import TextAndImageHero from '@components/sections/heros/TextAndImageHero.astro';
import FAQSection from '@components/sections/FAQSection.astro';
import RealScoutListings from '../components/RealScoutListings.astro';
import settings from '../config/settings.js';

const seo = {
  title: 'About Dr. Jan Duffy | Consenza Estates Specialist',
  description: 'Learn about Dr. Jan Duffy and her team—your Consenza Estates and Lennar homes specialists in Las Vegas.'
};
const team = settings.team ?? [];
const phoneDigits = settings.contact.phone.replace(/\D/g, '').slice(-10);
const phoneDisplay = phoneDigits ? `(${phoneDigits.slice(0,3)}) ${phoneDigits.slice(3,6)}-${phoneDigits.slice(6)}` : settings.contact.phone;
---

<Layout {seo}>
  <TextAndImageHero>
    <div slot="text-container">
      <h1>About Dr. Jan Duffy</h1>
      <p>Your dedicated Consenza Estates and Lennar homes specialist in Las Vegas.</p>
    </div>
    <div slot="image-container">
      <picture>
        <img
          src="/assets/images/headshots/jan-duffy-3.jpg"
          alt="Dr. Jan Duffy, REALTOR at Berkshire Hathaway HomeServices Nevada Properties"
          id="about-hero-image"
        />
      </picture>
    </div>
  </TextAndImageHero>

  <RealScoutListings sectionTitle="Homes for Sale in Las Vegas" />

  <TextSection>
    <h2>Professional Biography</h2>
    <p>With over 15 years of experience in Las Vegas real estate, Dr. Jan Duffy has established herself as the premier specialist for Lennar homes in the exclusive Consenza Estates community. Her comprehensive knowledge of Lennar's construction quality, floor plans, and "Everything's Included" features makes her an invaluable resource for buyers interested in this sought-after neighborhood.</p>
    
    <p>Dr. Duffy has applied her analytical skills to becoming an expert in Las Vegas real estate market trends. She has completed specialized training in new construction representation and luxury home marketing to better serve her discerning clientele.</p>
    
    <h3>Credentials & Certifications</h3>
    <ul>
      <li>Licensed Nevada REALTOR®</li>
      <li>Certified Luxury Home Marketing Specialist (CLHMS)</li>
      <li>New Home Construction Specialist</li>
      <li>Accredited Buyer's Representative (ABR)</li>
      <li>Certified Negotiation Expert (CNE)</li>
    </ul>
    
    <h3>Personal Connection to Las Vegas</h3>
    <p>As a long-time Las Vegas resident, Dr. Duffy has a deep appreciation for the lifestyle that the Consenza Estates community offers. She is actively involved in local charitable organizations and serves on the board of the Las Vegas Real Estate Association. Her personal knowledge of schools, amenities, and local attractions allows her to help clients truly understand the benefits of living in this exceptional community.</p>
    
    <h2>Why Work With Dr. Jan Duffy</h2>
    <h3>Consenza Estates & Lennar Specialist</h3>
    <p>Dr. Duffy specializes in Consenza Estates and Lennar new construction, with deep knowledge of floor plans and the local market.</p>
    <h3>Las Vegas Market Expertise</h3>
    <p>She serves the greater Las Vegas area and is certified in luxury home marketing and new home construction.</p>
    <h3>Berkshire Hathaway HomeServices Nevada Properties</h3>
    <p>Licensed (S.0197614.LLC) with Berkshire Hathaway HomeServices Nevada Properties for full-service representation.</p>
    
    <div class="contact-info">
      <h3>Contact Information</h3>
      <p>Phone: <a href={`tel:+1${phoneDigits}`}>{phoneDisplay}</a></p>
      <p>Email: <a href={`mailto:${settings.contact.email}`}>{settings.contact.email}</a></p>
      <p>Office: Berkshire Hathaway HomeServices Nevada Properties</p>
    </div>

    {team.length > 0 && (
      <div class="team-section">
        <h2>Meet the Team</h2>
        <p>Your dedicated Consenza Estates specialists—from listing to closing.</p>
        <ul class="team-list">
          {team.map((member) => (
            <li class="team-member">
              <strong>{member.name}</strong>
              <span class="team-role">{member.role}</span>
              {member.email && (
                <a href={`mailto:${member.email}`} class="team-contact">{member.email}</a>
              )}
              {member.phone && (
                <a href={`tel:+1${member.phone.replace(/\D/g, '').slice(-10)}`} class="team-contact">{member.phone}</a>
              )}
            </li>
          ))}
        </ul>
      </div>
    )}
  </TextSection>

  <FAQSection />
</Layout>

<style>
  .contact-info {
    background-color: var(--theme-surface-1);
    padding: 2rem;
    border-radius: var(--theme-shape-radius);
    margin-top: 2rem;
  }
  .team-section {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(255,255,255,0.1);
  }
  .team-section h2 {
    margin-bottom: 0.5rem;
  }
  .team-section > p {
    color: var(--theme-text-2, #666);
    margin-bottom: 1.5rem;
  }
  .team-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 1.25rem;
  }
  .team-member {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.5rem 1rem;
  }
  .team-member strong {
    min-width: 10rem;
  }
  .team-role {
    color: var(--theme-text-2, #666);
    font-size: 0.95rem;
  }
  .team-contact {
    margin-left: auto;
    font-size: 0.9rem;
  }
  .team-contact + .team-contact {
    margin-left: 0.5rem;
  }
</style>
