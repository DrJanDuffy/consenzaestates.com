
---
import { Container, TextSection, StickyTextImageSection } from '@components/odyssey-theme.js';
import Layout from '@layouts/Page.astro';
import HeroSection from '@components/sections/heros/HeroSection.astro';
import ThreeColumnTextSection from '@components/sections/ThreeColumnTextSection.astro';

const seo = {
  title: 'Consenza Estates Community | Dr. Jan Duffy',
  description: 'Consenza, a new Lennar community in Las Vegas, NV, offers single-story estate-style homes with Next Gen® suite, RV garages, Blue Diamond Road access, and Mountain\'s Edge Regional Park nearby.'
};
---

<Layout {seo}>
  <HeroSection>
    <div slot="text-container">
      <h1>Consenza Estates</h1>
      <p>Single-story, estate-style Lennar homes with Next Gen® suite and RV-height garages—minutes from Blue Diamond Road and Mountain's Edge Regional Park.</p>
    </div>
    <picture slot="image-container">
      <img
        src="/public/assets/images/home/consenza-community.jpg"
        alt="Consenza Estates Community"
        id="community-hero-image"
      />
    </picture>
  </HeroSection>

  <TextSection>
    <h2>About Consenza Estate Homes</h2>
    <p>Consenza, a new community in Las Vegas, NV, offers single-story, estate-style homes that include features such as Lennar's Next Gen® suite—the home within a home—as well as RV-height, four-bay tandem garages. With proximity to Blue Diamond Road, residents enjoy convenient commutes and travel, with plenty of opportunities for entertainment, shopping, and dining along the Las Vegas Strip.</p>
    
    <p>Nature lovers enjoy hours of outdoor recreation at nearby Mountain's Edge Regional Park, featuring a basketball court, playground, and more.</p>

    <h3>Standout Features</h3>
    <ul>
      <li><strong>Next Gen® suite</strong> — Lennar's home-within-a-home design for multigenerational living or private guest space</li>
      <li><strong>RV-height, four-bay tandem garages</strong> — Room for boats, RVs, and extra vehicles</li>
      <li><strong>Blue Diamond Road access</strong> — Easy commutes and quick reach to the Strip</li>
      <li><strong>Mountain's Edge Regional Park</strong> — Basketball, playground, and outdoor recreation close to home</li>
    </ul>
  </TextSection>

  <ThreeColumnTextSection>
    <div slot="column-1-body">
      <h3>Community Amenities</h3>
      <ul>
        <li>Resort-style pool and spa</li>
        <li>State-of-the-art fitness center</li>
        <li>Tennis and pickleball courts</li>
        <li>Community clubhouse</li>
        <li>Walking and biking trails</li>
        <li>Children's playground</li>
        <li>Dog park</li>
      </ul>
    </div>
    <div slot="column-2-body">
      <h3>Nearby Schools</h3>
      <ul>
        <li>Cortney Elementary School</li>
        <li>Becker Middle School</li>
        <li>Palo Verde High School</li>
        <li>Faith Lutheran Academy</li>
        <li>Alexander Dawson School</li>
        <li>UNLV (20 minutes)</li>
      </ul>
    </div>
    <div slot="column-3-body">
      <h3>Location & Nearby</h3>
      <ul>
        <li>Blue Diamond Road — commutes & travel</li>
        <li>Las Vegas Strip — entertainment, shopping, dining</li>
        <li>Mountain's Edge Regional Park — basketball, playground, trails</li>
        <li>Red Rock Canyon</li>
        <li>Medical facilities</li>
      </ul>
    </div>
  </ThreeColumnTextSection>

  <StickyTextImageSection>
    <div slot="text-container">
      <h2>HOA & Community Information</h2>
      <p>Consenza Estates is managed by a dedicated HOA that ensures the community maintains its premium standards and appearance.</p>
      
      <h3>HOA Details</h3>
      <p>Monthly Fee: $175-$225<br>
      Includes: Common area maintenance, community amenities, security, landscaping</p>
      
      <h3>Community Events</h3>
      <p>Consenza Estates hosts regular community events including summer pool parties, holiday celebrations, and neighborhood get-togethers. The active social committee ensures residents have plenty of opportunities to connect with neighbors and enjoy the amenities.</p>
    </div>
    <div slot="image-container">
      <picture>
        <img
          src="/public/assets/images/home/consenza-map.jpg"
          alt="Consenza Estates Community Map"
          loading="lazy"
        />
      </picture>
    </div>
  </StickyTextImageSection>

  <Container>
    <div class="community-gallery-section" style="margin: 4rem 0;">
      <h2 class="text-center">Explore Consenza Estates</h2>
      <p class="text-center" style="max-width: 700px; margin: 1rem auto 2rem;">Experience the beauty and luxury of Consenza Estates through our gallery of stunning community views, amenities, and home designs.</p>
      
      <div class="property-gallery">
        <div class="gallery-image animate-in delay-1">
          <img src="/public/assets/images/home/gallery-1.jpg" alt="Consenza Estates Home Exterior" />
        </div>
        <div class="gallery-image animate-in delay-1">
          <img src="/public/assets/images/home/gallery-2.jpg" alt="Consenza Estates Pool" />
        </div>
        <div class="gallery-image animate-in delay-2">
          <img src="/public/assets/images/home/gallery-3.jpg" alt="Consenza Estates Kitchen" />
        </div>
        <div class="gallery-image animate-in delay-2">
          <img src="/public/assets/images/home/gallery-4.jpg" alt="Consenza Estates Living Room" />
        </div>
        <div class="gallery-image animate-in delay-3">
          <img src="/public/assets/images/home/gallery-5.jpg" alt="Consenza Estates Bathroom" />
        </div>
        <div class="gallery-image animate-in delay-3">
          <img src="/public/assets/images/home/gallery-6.jpg" alt="Consenza Estates Bedroom" />
        </div>
      </div>
      
      <div style="text-align: center; margin-top: 2rem;">
        <a href="/properties" class="agent-button">View Available Properties</a>
      </div>
    </div>
  </Container>
</Layout>
