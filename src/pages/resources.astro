---
import { Container, TextSection } from '@components/odyssey-theme.js';
import Layout from '@layouts/Page.astro';
import HeroSection from '@components/sections/heros/HeroSection.astro';
import CalendlyLink from '@components/CalendlyLink.astro';
import { getSimplifyingMarketFeed } from '../utils/simplifyingMarketFeed.js';
import RealScoutListings from '../components/RealScoutListings.astro';

const seo = {
  title: 'Real Estate Resources | Dr. Jan Duffy',
  description: 'Access valuable resources for buying and selling in Consenza Estates. Market reports, mortgage calculators, and guides for Las Vegas real estate.'
};

const feedItems = await getSimplifyingMarketFeed(8);
---

<Layout {seo}>
  <HeroSection>
    <div slot="text-container">
      <h1>Homebuyer Resources</h1>
      <p>Helpful tools and information for Consenza Estates buyers and sellers.</p>
    </div>
    <picture slot="image-container">
      <img
        src="/assets/images/home/resources-hero.jpg"
        alt="Real Estate Resources"
        id="resources-hero-image"
      />
    </picture>
  </HeroSection>

  <RealScoutListings sectionTitle="Homes for Sale in Las Vegas" />

  <Container>
    <div class="resources-grid">
      <div class="resource-card">
        <h2>Consenza Estates Buying Guide</h2>
        <p>This comprehensive guide walks you through everything you need to know about purchasing a home in Consenza Estates, from understanding the community to navigating the closing process.</p>
        <ul class="resource-topics">
          <li>Understanding Lennar's buying process</li>
          <li>Financing options for luxury homes</li>
          <li>New construction vs. resale considerations</li>
          <li>Home inspection checklist</li>
          <li>Closing timeline and requirements</li>
        </ul>
        <a href="#" class="resource-cta">Download Buying Guide</a>
      </div>
      
      <div class="resource-card calculator">
        <h2>Mortgage Calculator</h2>
        <p>Estimate your monthly payments for Consenza Estates properties.</p>
        
        <div class="calculator-form">
          <div class="calc-field">
            <label for="home-price">Home Price</label>
            <input type="number" id="home-price" placeholder="$750,000" />
          </div>
          
          <div class="calc-field">
            <label for="down-payment">Down Payment</label>
            <input type="number" id="down-payment" placeholder="$150,000" />
          </div>
          
          <div class="calc-field">
            <label for="interest-rate">Interest Rate (%)</label>
            <input type="number" id="interest-rate" placeholder="5.5" step="0.125" />
          </div>
          
          <div class="calc-field">
            <label for="loan-term">Loan Term (years)</label>
            <select id="loan-term">
              <option value="30">30 Years</option>
              <option value="20">20 Years</option>
              <option value="15">15 Years</option>
              <option value="10">10 Years</option>
            </select>
          </div>
          
          <button id="calculate-btn" class="calc-button">Calculate Payment</button>
          
          <div class="calc-results">
            <div class="result-item">
              <span>Principal & Interest:</span>
              <span id="principal-interest">$3,400/mo</span>
            </div>
            
            <div class="result-item">
              <span>Property Taxes:</span>
              <span id="property-taxes">$625/mo</span>
            </div>
            
            <div class="result-item">
              <span>HOA Fees:</span>
              <span id="hoa-fees">$200/mo</span>
            </div>
            
            <div class="result-item total">
              <span>Estimated Total:</span>
              <span id="total-payment">$4,225/mo</span>
            </div>
          </div>
        </div>
      </div>
      
      <div class="resource-card">
        <h2>Las Vegas Relocation Guide</h2>
        <p>Moving to Las Vegas? This guide provides essential information for newcomers, including insights about neighborhoods, schools, utilities, and lifestyle considerations.</p>
        <ul class="resource-topics">
          <li>Las Vegas climate and weather patterns</li>
          <li>School district information</li>
          <li>Transportation and commuting</li>
          <li>Recreation and entertainment</li>
          <li>Setting up utilities and services</li>
        </ul>
        <a href="#" class="resource-cta">Download Relocation Guide</a>
      </div>
      
      <div class="resource-card market-report">
        <h2>Consenza Estates Market Report</h2>
        <p>Stay informed about current market conditions, trends, and forecasts specific to Consenza Estates. This report is updated monthly with the latest data.</p>
        
        <div class="market-stats">
          <div class="stat-item">
            <span class="stat-value">$850K</span>
            <span class="stat-label">Median Sale Price</span>
          </div>
          
          <div class="stat-item">
            <span class="stat-value">14</span>
            <span class="stat-label">Avg. Days on Market</span>
          </div>
          
          <div class="stat-item">
            <span class="stat-value">98%</span>
            <span class="stat-label">List to Sale Ratio</span>
          </div>
          
          <div class="stat-item">
            <span class="stat-value">8</span>
            <span class="stat-label">Active Listings</span>
          </div>
        </div>
        
        <a href="#" class="resource-cta">Download Full Report</a>
      </div>
    </div>
    
    {feedItems.length > 0 && (
      <section class="market-insights">
        <TextSection>
          <h2>Market Insights</h2>
          <p>Latest articles from Simplifying the Market—selling tips, market trends, and buyer guidance.</p>
        </TextSection>
        <div class="insights-grid">
          {feedItems.map((item) => (
            <article class="insight-card">
              <a href={item.link} target="_blank" rel="noopener noreferrer" class="insight-link">
                {item.image && (
                  <div class="insight-image-wrap">
                    <img
                      src={item.image}
                      alt={item.title}
                      loading="lazy"
                      width="400"
                      height="225"
                      class="insight-image"
                      referrerpolicy="no-referrer"
                    />
                  </div>
                )}
                <div class="insight-body">
                  <h3 class="insight-title">{item.title}</h3>
                  {item.description && <p class="insight-description">{item.description}</p>}
                  <span class="insight-cta">Read article →</span>
                </div>
              </a>
            </article>
          ))}
        </div>
      </section>
    )}

    <div class="schedule-cta-section">
      <TextSection>
        <h2>Discuss Your Consenza Estates Plans</h2>
        <p>Schedule a call to discuss market updates, new listings, and your goals. Free 15‑minute call — no obligation.</p>
        <p>
          <CalendlyLink utmCampaign="resources_cta">Schedule a call</CalendlyLink>
        </p>
      </TextSection>
    </div>
  </Container>
</Layout>

<style>
  .schedule-cta-section {
    margin-top: 3rem;
    padding: 2rem 0;
  }
  .schedule-cta-section p:last-of-type {
    margin-top: 1rem;
  }
  .market-insights {
    margin: 4rem 0;
  }
  .insights-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
    margin-top: 1.5rem;
  }
  .insight-card {
    background-color: var(--theme-surface-1);
    border-radius: var(--theme-shape-radius);
    overflow: hidden;
    transition: box-shadow 0.3s ease;
  }
  .insight-card:hover {
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
  }
  .insight-link {
    display: block;
    text-decoration: none;
    color: inherit;
    height: 100%;
  }
  .insight-image-wrap {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background-color: var(--theme-surface-2);
  }
  .insight-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .insight-body {
    padding: 1.25rem;
  }
  .insight-title {
    font-size: 1.05rem;
    margin: 0 0 0.5rem;
    line-height: 1.35;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .insight-description {
    font-size: 0.9rem;
    color: var(--theme-text-2, #555);
    margin: 0 0 0.75rem;
    line-height: 1.45;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .insight-cta {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--theme-primary, #b8860b);
  }

  .resources-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
    margin: 2rem 0 4rem;
  }
  
  .resource-card {
    background-color: var(--theme-surface-1);
    padding: 2rem;
    border-radius: var(--theme-shape-radius);
    height: 100%;
    display: flex;
    flex-direction: column;
  }
  
  .resource-card h2 {
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid var(--theme-primary);
  }
  
  .resource-topics {
    margin: 1.5rem 0;
    padding-left: 1.5rem;
  }
  
  .resource-topics li {
    margin-bottom: 0.5rem;
  }
  
  .resource-cta {
    display: inline-block;
    padding: 0.75rem 1.5rem;
    background-color: var(--theme-primary);
    color: var(--theme-on-primary);
    text-decoration: none;
    border-radius: var(--theme-button-border-radius);
    font-weight: bold;
    margin-top: auto;
    align-self: flex-start;
    transition: background-color 0.3s ease;
  }
  
  .resource-cta:hover {
    background-color: var(--theme-primary-hover);
  }
  
  /* Calculator Styles */
  .calculator {
    background-color: var(--theme-surface-2);
  }
  
  .calculator-form {
    margin-top: 1.5rem;
  }
  
  .calc-field {
    margin-bottom: 1rem;
  }
  
  .calc-field label {
    display: block;
    margin-bottom: 0.5rem;
    font-weight: bold;
  }
  
  .calc-field input,
  .calc-field select {
    width: 100%;
    padding: 0.75rem;
    border: 1px solid #ddd;
    border-radius: 0.25rem;
  }
  
  .calc-button {
    background-color: var(--theme-primary);
    color: var(--theme-on-primary);
    padding: 0.75rem 1.5rem;
    border: none;
    border-radius: var(--theme-button-border-radius);
    cursor: pointer;
    font-weight: bold;
    margin: 1rem 0;
    width: 100%;
  }
  
  .calc-button:hover {
    background-color: var(--theme-primary-hover);
  }
  
  .calc-results {
    background-color: var(--theme-bg);
    padding: 1rem;
    border-radius: 0.5rem;
    margin-top: 1rem;
  }
  
  .result-item {
    display: flex;
    justify-content: space-between;
    margin-bottom: 0.5rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid #eee;
  }
  
  .result-item.total {
    font-weight: bold;
    font-size: 1.1em;
    border-bottom: none;
    margin-top: 0.5rem;
    padding-top: 0.5rem;
    border-top: 2px solid #ddd;
  }
  
  /* Market Report Styles */
  .market-report {
    background-color: var(--theme-surface-1);
  }
  
  .market-stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    margin: 2rem 0;
  }
  
  .stat-item {
    text-align: center;
  }
  
  .stat-value {
    display: block;
    font-size: 2rem;
    font-weight: bold;
    color: var(--theme-primary);
  }
  
  .stat-label {
    display: block;
    font-size: 0.9rem;
  }
  
  /* Newsletter Styles */
  .newsletter-signup {
    background-color: var(--theme-surface-2);
    padding: 2rem;
    border-radius: var(--theme-shape-radius);
    margin: 2rem 0;
  }
  
  .newsletter-form {
    margin-top: 2rem;
  }
  
  .form-row {
    display: flex;
    gap: 1.5rem;
    margin-bottom: 1.5rem;
  }
  
  @media (max-width: 768px) {
    .form-row {
      flex-direction: column;
      gap: 1rem;
    }
  }
  
  .form-field {
    flex: 1;
  }
  
  .form-field label {
    display: block;
    margin-bottom: 0.5rem;
    font-weight: bold;
  }
  
  .form-field input {
    width: 100%;
    padding: 0.75rem;
    border: 1px solid #ddd;
    border-radius: 0.25rem;
  }
  
  .form-interests {
    margin-bottom: 1.5rem;
  }
  
  .interest-label {
    font-weight: bold;
    margin-bottom: 0.5rem;
  }
  
  .interest-options {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.5rem 2rem;
  }
  
  @media (max-width: 500px) {
    .interest-options {
      grid-template-columns: 1fr;
    }
  }
  
  .interest-option {
    display: flex;
    align-items: center;
  }
  
  .interest-option input {
    margin-right: 0.5rem;
  }
  
  .subscribe-button {
    background-color: var(--theme-primary);
    color: var(--theme-on-primary);
    padding: 0.75rem 1.5rem;
    border: none;
    border-radius: var(--theme-button-border-radius);
    cursor: pointer;
    font-weight: bold;
  }
  
  .subscribe-button:hover {
    background-color: var(--theme-primary-hover);
  }
</style>
