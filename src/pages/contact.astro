---
import { Container, TextSection } from '@components/odyssey-theme.js';
import Layout from '@layouts/Page.astro';
import HeroSection from '@components/sections/heros/HeroSection.astro';
import CalendlyInline from '@components/CalendlyInline.astro';
import CalendlyLink from '@components/CalendlyLink.astro';
import RealScoutListings from '../components/RealScoutListings.astro';
import settings from '../config/settings.js';

const seo = {
  title: 'Contact Dr. Jan Duffy | Consenza Estates Specialist',
  description: 'Get in touch with Dr. Jan Duffy, your Consenza Estates specialist in Las Vegas. Schedule a strategy meeting or request information about this exclusive community.'
};

const phoneDigits = settings.contact.phone.replace(/\D/g, '').slice(-10);
const phoneDisplay = phoneDigits ? `(${phoneDigits.slice(0,3)}) ${phoneDigits.slice(3,6)}-${phoneDigits.slice(6)}` : settings.contact.phone;
---

<Layout {seo}>
  <HeroSection>
    <div slot="text-container">
      <h1>Contact Dr. Jan Duffy</h1>
      <p>I'm here to answer your questions about Consenza Estates and help you find your dream home. Schedule a time that works for you.</p>
    </div>
    <picture slot="image-container">
      <img
        src="/assets/images/home/contact-image.jpg"
        alt="Contact Dr. Jan Duffy"
        id="contact-hero-image"
      />
    </picture>
  </HeroSection>

  <RealScoutListings sectionTitle="Homes for Sale in Las Vegas" />

  <Container>
    <div class="contact-wrapper">
      <div class="contact-info">
        <div class="contact-agent-block">
          <img src="/assets/images/headshots/jan-duffy-2.jpg" alt="Dr. Jan Duffy, Consenza Estates Specialist" class="contact-agent-photo" width="120" height="120" />
          <div class="contact-agent-text">
            <strong>Dr. Jan Duffy</strong>
            <span>Your Consenza Estates & Lennar homes specialist</span>
          </div>
        </div>
        <TextSection>
          <h2>Get In Touch</h2>
          <p>I'm dedicated to providing exceptional service to buyers and sellers in Consenza Estates. Whether you're looking to purchase a new Lennar home or sell your current property, I'm here to guide you through the process.</p>
          
          <div class="contact-methods">
            <div class="contact-method animate-fadeInUp">
              <h3>Call or Text</h3>
              <p><a href={`tel:+1${phoneDigits}`}>{phoneDisplay}</a></p>
            </div>
            
            <div class="contact-method animate-fadeInUp animate-delay-100">
              <h3>Email</h3>
              <p><a href={`mailto:${settings.contact.email}`}>{settings.contact.email}</a></p>
            </div>
            
            <div class="contact-method">
              <h3>Office Location</h3>
              <p>{settings.contact.address}</p>
            </div>
            
            <div class="contact-method">
              <h3>Office Hours</h3>
              <p>Monday–Friday: 9am–6pm<br>
              Saturday: 10am–4pm<br>
              Sunday: By appointment</p>
            </div>
          </div>
          
          <div class="cta-buttons">
            <CalendlyLink class="cta-button primary" utmCampaign="contact_hero_show">Schedule a free strategy call</CalendlyLink>
            <CalendlyLink class="cta-button secondary" buttonStyle="outlined" utmCampaign="contact_hero_seller">Get your home's value</CalendlyLink>
          </div>
          <p class="cta-trust" style="margin-top: 0.75rem; font-size: 0.9rem;">Free 15‑minute call — no obligation.</p>
        </TextSection>
      </div>
      
      <div class="calendly-container" id="schedule">
        <h2>Schedule a Time With Me</h2>
        <CalendlyInline minWidth="320px" height="700px" utmCampaign="contact_inline" />
      </div>
    </div>
    
    <div class="market-analysis-cta" id="market-analysis">
      <TextSection>
        <h2>Consenza Estates Market Analysis</h2>
        <p>Thinking about selling your Consenza Estates home? Schedule a strategy meeting and we'll go over your home's value and the best approach for today's market.</p>
        <p>
          <CalendlyLink utmCampaign="contact_market_analysis">Schedule a free strategy call</CalendlyLink>
        </p>
      </TextSection>
    </div>
  </Container>
</Layout>

<style>
  .contact-agent-block {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.5rem;
    padding: 1rem;
    background: var(--theme-surface-1);
    border-radius: var(--theme-shape-radius);
    border: 1px solid rgba(212, 175, 55, 0.15);
  }
  .contact-agent-photo {
    width: 80px;
    height: 80px;
    object-fit: cover;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .contact-agent-text {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .contact-agent-text strong {
    color: var(--luxury-gold, #D4AF37);
  }
  .contact-agent-text span {
    font-size: 0.9rem;
    opacity: 0.9;
  }
  
  .contact-wrapper {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    margin-bottom: 4rem;
  }
  
  @media (max-width: 768px) {
    .contact-wrapper {
      grid-template-columns: 1fr;
    }
  }
  
  .contact-methods {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    margin: 2rem 0;
  }
  
  #contact-hero-image {
    box-shadow: var(--luxury-shadow-lg);
    transition: all 0.5s ease;
    border: 1px solid rgba(212, 175, 55, 0.1);
  }
  
  #contact-hero-image:hover {
    transform: scale(1.02);
    box-shadow: 0 25px 50px rgba(212, 175, 55, 0.15);
  }
  
  @media (max-width: 500px) {
    .contact-methods {
      grid-template-columns: 1fr;
    }
  }
  
  .contact-method {
    padding: 1.5rem;
    background-color: white;
    border-radius: var(--theme-shape-radius);
    box-shadow: var(--luxury-shadow-sm);
    transition: all 0.3s ease;
    border: 1px solid rgba(212, 175, 55, 0.1);
  }
  
  .contact-method:hover {
    transform: translateY(-5px);
    box-shadow: var(--luxury-shadow-md);
    border: 1px solid rgba(212, 175, 55, 0.3);
  }
  
  .contact-method a {
    color: inherit;
    text-decoration: none;
  }
  
  .contact-method a:hover {
    color: var(--luxury-gold);
  }
  
  .contact-method h3 {
    margin-bottom: 0.5rem;
    color: var(--luxury-gold);
    position: relative;
    display: inline-block;
  }
  
  .contact-method h3::after {
    content: '';
    position: absolute;
    bottom: -3px;
    left: 0;
    width: 30px;
    height: 2px;
    background-color: var(--luxury-gold);
  }
  
  .cta-buttons {
    display: flex;
    gap: 1rem;
    margin-top: 2rem;
    flex-wrap: wrap;
  }
  
  @media (max-width: 500px) {
    .cta-buttons {
      flex-direction: column;
    }
  }
  
  .cta-button.primary {
    background-color: var(--theme-primary) !important;
    color: var(--theme-on-primary) !important;
  }
  
  .cta-button.primary:hover {
    background-color: var(--theme-primary-hover) !important;
  }
  
  .cta-button.secondary {
    background-color: var(--theme-surface-1) !important;
    color: var(--theme-on-surface-1) !important;
    border: 2px solid var(--theme-primary);
  }
  
  .calendly-container {
    background-color: var(--theme-surface-1);
    padding: 1.5rem;
    border-radius: var(--theme-shape-radius);
    box-shadow: var(--luxury-shadow-md);
    border: 1px solid rgba(212, 175, 55, 0.1);
  }
  
  .calendly-container h2 {
    margin-bottom: 1rem;
  }
  
  .market-analysis-cta {
    margin-top: 4rem;
    background-color: var(--theme-surface-2);
    padding: 2.5rem;
    border-radius: var(--theme-shape-radius);
    box-shadow: var(--luxury-shadow-lg);
  }
</style>
